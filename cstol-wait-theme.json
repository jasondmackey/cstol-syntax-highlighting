{
       "name": "CSTOL Dark Theme",
       "type": "dark",
       "colors": {
              "editor.background": "#1e1e1e",
              "editor.foreground": "#d4d4d4",
              "activityBar.background": "#2d2d30",
              "sideBar.background": "#252526",
              "statusBar.background": "#007acc",
              "statusBar.foreground": "#ffffff",
              "tab.activeBackground": "#1e1e1e",
              "tab.inactiveBackground": "#2d2d30",
              "tab.activeForeground": "#ffffff",
              "tab.inactiveForeground": "#969696",
              "editorLineNumber.foreground": "#858585",
              "editorCursor.foreground": "#aeafad",
              "editor.selectionBackground": "#264f78",
              "editor.lineHighlightBackground": "#2a2d2e"
       },
       "tokenColors": [
              {
                     "name": "Wait statements",
                     "scope": [
                            "keyword.control.wait.cstol"
                     ],
                     "settings": {
                            "foreground": "#000000",
                            "background": "#FFFF00",
                            "fontStyle": "bold"
                     }
              },
              {
                     "name": "Comments",
                     "scope": [
                            "comment",
                            "punctuation.definition.comment"
                     ],
                     "settings": {
                            "foreground": "#6A9955",
                            "fontStyle": "italic"
                     }
              },
              {
                     "name": "Control flow and conditionals",
                     "scope": [
                            "keyword.control.flow.cstol",
                            "keyword.control.conditional.cstol",
                            "keyword.other.unit.cstol"
                     ],
                     "settings": {
                            "foreground": "#569CD6"
                     }
              },
              {
                     "name": "CSTOL Commands",
                     "scope": [
                            "keyword.control.command.cstol",
                            "entity.name.type.cstol"
                     ],
                     "settings": {
                            "foreground": "#DCDCAA"
                     }
              },
              {
                     "name": "Variables",
                     "scope": [
                            "variable.parameter.cstol"
                     ],
                     "settings": {
                            "foreground": "#9CDCFE"
                     }
              },
              {
                     "name": "Labels",
                     "scope": [
                            "entity.name.label.cstol"
                     ],
                     "settings": {
                            "foreground": "#9CDCFE",
                            "fontStyle": "bold"
                     }
              },
              {
                     "name": "Strings",
                     "scope": [
                            "string.quoted.double.cstol",
                            "constant.character.escape.cstol"
                     ],
                     "settings": {
                            "foreground": "#CE9178"
                     }
              },
              {
                     "name": "Numbers",
                     "scope": [
                            "constant.numeric"
                     ],
                     "settings": {
                            "foreground": "#B5CEA8"
                     }
              },
              {
                     "name": "Boolean constants",
                     "scope": [
                            "constant.language.boolean.cstol"
                     ],
                     "settings": {
                            "foreground": "#569CD6"
                     }
              },
              {
                     "name": "Enum and type constants",
                     "scope": [
                            "constant.other.enum.cstol",
                            "variable.other.constant.cstol"
                     ],
                     "settings": {
                            "foreground": "#4EC9B0"
                     }
              },
              {
                     "name": "Operators",
                     "scope": [
                            "keyword.operator.comparison.cstol",
                            "keyword.operator.logical.cstol",
                            "keyword.operator.arithmetic.cstol"
                     ],
                     "settings": {
                            "foreground": "#D4D4D4"
                     }
              },
              {
                     "name": "GOTO statements",
                     "scope": [
                            "keyword.control.flow.goto.cstol"
                     ],
                     "settings": {
                            "foreground": "#000000",
                            "background": "#CCA8DD",
                            "fontStyle": "bold"
                     }
              }
       ]
}